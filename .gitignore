# === OS Files ===
.DS_Store
Thumbs.db
desktop.ini

# === VS Code ===
.vscode/
*.code-workspace

# === Git ===
.git/

# === Rust / Cargo ===
# Build artifacts. Largest single offender — keep this committed-out.
target/
# rustfmt backup files
**/*.rs.bk
# Cargo's local override config (per-machine paths, etc.). The shared
# `.cargo/config.toml` IS committed (xtask alias).
.cargo/config.local.toml
# Coverage / profiling output
*.profraw
*.profdata
flamegraph.svg
perf.data*
# Note: Cargo.lock IS committed (this workspace produces a binary).

# === Project ===
# Local sandbox for moved files we're not allowed to delete.
.trash/
# Local staging checkout/copy for the future public repository. It has its own
# history and must not be tracked by this private development repo.
continuity-public/

# === Node.js ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Python ===
__pycache__/
*.py[cod]
*.pyo
*.pyd
env/
venv/
*.egg-info/

# === Logs ===
*.log

# === Build / Dist ===
dist/
build/
out/

# === JetBrains IDEs ===
.idea/
*.iml

# Public staging: upload these to GitHub Releases; do not commit them.
releases/
